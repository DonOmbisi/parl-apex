APP_ENV=development
UVICORN_WORKERS=1

# Local default is ./data. On Render, set DATA_DIR=/data so SQLite and Kuzu
# write to the mounted persistent disk.
DATA_DIR=./data

GROQ_API_KEY=gsk-...

# SQLite. If omitted, PARL APEX uses DATA_DIR/app.db.
DATABASE_URL=

# PostgreSQL (uncomment and fill in for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# Valyu API key used to create scheduled tender research tasks.
VALYU_API_KEY=

# Shared secret expected on Valyu tender webhook deliveries.
VALYU_WEBHOOK_SECRET=

# Base URL for EspoCRM. Locally this is usually http://192.168.1.110.
# On Render, set this to the EspoCRM VM's Tailscale IP, e.g. http://100.x.x.x.
ESPOCRM_BASE_URL=

# API key used by PARL APEX to create/update general EspoCRM records such as Accounts.
ESPOCRM_API_KEY=

# API key used by PARL APEX to create/update EspoCRM Tender records.
ESPOCRM_TENDER_API_KEY=

# API key used by PARL APEX to create EspoCRM Finding records from SPOT reports.
ESPOCRM_FINDING_API_KEY=

# API key used by PARL APEX to read Opportunity, Account, Contact, and Product entities for quotation generation.
# This should be a scoped EspoCRM API user with Read access only to these entities.
ESPOCRM_QUOTATION_API_KEY=

# Public base URL for this PARL APEX service, used to build Valyu webhook callback URLs.
PARL_APEX_WEBHOOK_BASE_URL=

# Tailscale auth key used on Render so PARL APEX can reach EspoCRM on the office LAN.
TAILSCALE_AUTH_KEY=
